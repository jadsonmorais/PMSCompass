# OHIP Environment — preencha com os valores do Developer Portal
# ------------------------------------------------------------------
# Endereço do tenant (sem barra final). Cada cliente tem o seu.
OHIP_HOST=https://your-tenant.hospitality.oracleindustry.com

# Application Key gerada no OHIP Developer Portal (UUID v4)
OHIP_APP_KEY=41ecd082-8997-4c69-af34-2f72b83645ff

# Credenciais OAuth do app
OHIP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
OHIP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Tipo de fluxo: "password" (Resource Owner) ou "client_credentials"
OHIP_GRANT_TYPE=password

# --- Apenas para grant_type=password (Resource Owner) ---
OHIP_USERNAME=integration_user
OHIP_PASSWORD=********

# --- Apenas para grant_type=client_credentials (OCIM) ---
OHIP_ENTERPRISE_ID=ENT12345
OHIP_SCOPE=urn:opc:hgbu:ws:__myscopes__

# Código da propriedade (Hotel/Property Code do OPERA Cloud)
OHIP_HOTEL_ID=PROP01
